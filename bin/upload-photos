#!/usr/bin/env bash
# Uploads a folder of exported photos to Cloudflare R2 and prints ready-to-paste
# post markdown. Requires `rclone` configured with an "r2" remote (see README.md).
set -euo pipefail

BUCKET="electricentity"
DOMAIN="img.electricentity.com"
REMOTE="r2"
MAX_DIM=2400
QUALITY=82

if [ $# -ne 2 ]; then
  echo "Usage: $0 <post-slug> <path-to-photo-folder>" >&2
  exit 1
fi

slug="$1"
source_dir="$2"

if ! command -v rclone >/dev/null 2>&1; then
  echo "rclone not found. Install with 'brew install rclone', then run 'rclone config' once to add the '$REMOTE' remote (see README.md)." >&2
  exit 1
fi

if ! command -v sips >/dev/null 2>&1; then
  echo "sips not found (expected on macOS, used to read image dimensions and downscale photos for web display)." >&2
  exit 1
fi

if ! command -v jpegtran >/dev/null 2>&1; then
  echo "jpegtran not found. Install with 'brew install jpeg-turbo' (used to losslessly re-encode photos as progressive JPEGs, so they render low-res-to-sharp as they load instead of appearing all at once)." >&2
  exit 1
fi

if [ ! -d "$source_dir" ]; then
  echo "No such folder: $source_dir" >&2
  exit 1
fi

shopt -s nullglob nocaseglob
photos=("$source_dir"/*.jpg "$source_dir"/*.jpeg)
shopt -u nullglob nocaseglob

if [ ${#photos[@]} -eq 0 ]; then
  echo "No .jpg/.jpeg files found in $source_dir" >&2
  exit 1
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT

echo "Uploading ${#photos[@]} photo(s) to $REMOTE:$BUCKET/$slug/ ..." >&2
for photo in "${photos[@]}"; do
  filename="$(basename "$photo")"

  # Full-quality version, kept behind the lightbox click: losslessly re-encoded as
  # progressive JPEG (same pixels, renders low-res-to-sharp as it downloads).
  jpegtran -copy all -progressive -optimize -outfile "$tmpdir/full_$filename" "$photo"
  rclone copyto "$tmpdir/full_$filename" "$REMOTE:$BUCKET/$slug/full/$filename"

  # Default display version: downscaled to the site's max render width (the post
  # column caps out at 810px) so phones aren't pulling multi-megabyte originals.
  sips -Z "$MAX_DIM" -s formatOptions "$QUALITY" "$photo" --out "$tmpdir/$filename" >/dev/null
  jpegtran -copy all -progressive -optimize -outfile "$tmpdir/final_$filename" "$tmpdir/$filename"
  rclone copyto "$tmpdir/final_$filename" "$REMOTE:$BUCKET/$slug/$filename"
done

echo >&2
echo "Done. Paste this into the post:" >&2
echo >&2

for photo in "${photos[@]}"; do
  filename="$(basename "$photo")"
  alt="$(echo "$filename" | sed -E 's/\.[Jj][Pp][Ee]?[Gg]$//; s/[-_]+/ /g')"
  width="$(sips -g pixelWidth "$tmpdir/$filename" | awk '/pixelWidth/ {print $2}')"
  height="$(sips -g pixelHeight "$tmpdir/$filename" | awk '/pixelHeight/ {print $2}')"
  echo "[![${alt}](https://${DOMAIN}/${slug}/${filename}){: class=\"bigger-image\" loading=\"lazy\" width=\"${width}\" height=\"${height}\" }](https://${DOMAIN}/${slug}/full/${filename}){: data-fslightbox=\"${slug}\" }"
done
