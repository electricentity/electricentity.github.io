#!/usr/bin/env bash
# Runs the site locally via Docker, no local Ruby install needed.
# Open http://localhost:4000 once it's up. Ctrl-C to stop.
set -euo pipefail
cd "$(dirname "$0")/.."

docker run --rm -it \
  -v "$PWD:/srv/jekyll" \
  -p 4000:4000 \
  jekyll/jekyll:4.4 \
  bash -c "bundle install && bundle exec jekyll serve --config _config.yml,_config-dev.yml --livereload -H 0.0.0.0"
